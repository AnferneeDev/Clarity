# ============================================
# Clarity v3 — Development Dockerfile
# Runs Electron in dev mode with X11 forwarding
# ============================================

FROM node:22-slim

# Install Electron system dependencies (Linux)
RUN apt-get update && apt-get install -y \
    libnss3 \
    libgtk-3-0 \
    libgbm1 \
    libasound2 \
    libxss1 \
    libxtst6 \
    xdg-utils \
    libdrm2 \
    libcurl4 \
    libglib2.0-0 \
    libnotify4 \
    browserpass \
    --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Cache npm install layer
COPY package.json package-lock.json ./
RUN npm install

# Copy project source
COPY . .

# Default command: start dev server
CMD ["npm", "run", "dev"]
