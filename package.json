{
  "name": "clarity",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/web",
      "apps/mobile"
    ]
  },
  "scripts": {
    "dev:desktop": "cd apps/desktop && npm run dev",
    "dev:web": "npm run dev -w apps/web",
    "dev:mobile": "npm run dev -w apps/mobile",
    "make:desktop": "cd apps/desktop && npm run make",
    "lint": "cd apps/desktop && npm run lint"
  }
}
